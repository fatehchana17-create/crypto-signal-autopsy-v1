# Core paths
CSA_DB_PATH=data/autopsy.sqlite
CSA_EXPORT_DIR=exports

# Universe
CSA_DEX_CHAIN=base
CSA_GOPLUS_CHAIN_ID=8453
CSA_CEX_TOP_N=100

# Optional API keys/tokens.
# CoinGecko works best with a Demo or Pro key, but the scanner can try unauthenticated demo calls.
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=

# GoPlus currently documents Bearer auth for token security.
# Without this, V1 logs security_status=skipped_no_token unless CSA_REQUIRE_GOPLUS=true.
GOPLUS_ACCESS_TOKEN=
CSA_REQUIRE_GOPLUS=false

# DEX hard filters. These are test settings, not claims about truth.
CSA_MIN_LIQUIDITY_USD=500000
CSA_MIN_VOLUME_24H_USD=100000
CSA_MIN_PAIR_AGE_HOURS=6
CSA_MAX_PRICE_CHANGE_H1_PCT=75
CSA_MAX_BUY_TAX_PCT=10
CSA_MAX_SELL_TAX_PCT=10

# Signal settings
CSA_VOLUME_SPIKE_MULTIPLE=3
CSA_CLEAN_MOMENTUM_MIN_H1_PCT=3
CSA_LIQUIDITY_EXPANSION_MIN_PCT=5
CSA_DELAYED_ENTRY_MINUTES=5
CSA_ESTIMATED_COST_PCT=0.5
