# Core paths
CSA_DB_PATH=data/autopsy.sqlite
CSA_EXPORT_DIR=exports

# Universe
CSA_DEX_CHAIN=base
CSA_GOPLUS_CHAIN_ID=8453
CSA_CEX_TOP_N=100

# Optional API keys/tokens.
# CoinGecko works best with a Demo or Pro key, but the scanner can try unauthenticated demo calls.
COINGECKO_DEMO_API_KEY=
COINGECKO_PRO_API_KEY=

# GoPlus token security is optional but improves V2 risk scoring.
# Without this, V2 records security_status=skipped_no_token unless CSA_REQUIRE_GOPLUS=true.
GOPLUS_ACCESS_TOKEN=
GOPLUS_API_KEY=
CSA_REQUIRE_GOPLUS=false

# V3 smart wallet tracking. The scanner still works without these keys.
CSA_WALLET_MODULE_ENABLED=true
CSA_WALLET_PROVIDER=moralis
MORALIS_API_KEY=
BIRDEYE_API_KEY=
CSA_WALLET_HISTORY_DAYS=7
CSA_WALLET_PAIR_LIMIT=25
CSA_WALLET_TRADE_LIMIT=100

# Legacy V1 hard filters are kept for compatibility.
# V2 hard reject/scoring thresholds live in crypto_signal_autopsy/config.py.
CSA_MIN_LIQUIDITY_USD=500000
CSA_MIN_VOLUME_24H_USD=100000
CSA_MIN_PAIR_AGE_HOURS=6
CSA_MAX_PRICE_CHANGE_H1_PCT=75
CSA_MAX_BUY_TAX_PCT=10
CSA_MAX_SELL_TAX_PCT=10

# Signal settings
CSA_VOLUME_SPIKE_MULTIPLE=3
CSA_CLEAN_MOMENTUM_MIN_H1_PCT=3
CSA_LIQUIDITY_EXPANSION_MIN_PCT=5
CSA_DELAYED_ENTRY_MINUTES=5
CSA_ESTIMATED_COST_PCT=0.5
